{
  "name": "pr-buildr-vscode",
  "displayName": "PR Builder",
  "description": "AI-powered pull request builder for VS Code",
  "version": "0.1.0",
  "publisher": "pr-buildr",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pr-buildr.createPR",
        "title": "PR Builder: Create Pull Request",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "pr-buildr.setBase",
        "title": "PR Builder: Set Base Branch"
      },
      {
        "command": "pr-buildr.showBase",
        "title": "PR Builder: Show Base Branch"
      },
      {
        "command": "pr-buildr.clearBase",
        "title": "PR Builder: Clear Base Branch"
      },
      {
        "command": "pr-buildr.regenerate",
        "title": "PR Builder: Regenerate Draft"
      },
      {
        "command": "pr-buildr.setOpenAIKey",
        "title": "PR Builder: Set OpenAI API Key"
      },
      {
        "command": "pr-buildr.setAnthropicKey",
        "title": "PR Builder: Set Anthropic API Key"
      },
      {
        "command": "pr-buildr.setOpenAICompatibleKey",
        "title": "PR Builder: Set OpenAI-Compatible API Key"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "pr-buildr.createPR",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ]
    },
    "configuration": {
      "title": "PR Builder",
      "properties": {
        "pr-buildr.defaultProvider": {
          "type": "string",
          "default": "openai",
          "enum": ["openai", "anthropic", "ollama", "openai-compatible"],
          "description": "Default AI provider for generating PR drafts"
        },
        "pr-buildr.defaultModel": {
          "type": "string",
          "default": "",
          "description": "Default AI model (leave empty to use provider default)"
        },
        "pr-buildr.ollamaBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Base URL for Ollama server"
        },
        "pr-buildr.openaiCompatibleBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL for OpenAI-compatible API server"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsup --watch",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@pr-buildr/core": "workspace:*",
    "@types/vscode": "^1.85.0",
    "@vscode/webview-ui-toolkit": "^1.4.0"
  },
  "keywords": ["pull-request", "github", "ai", "vscode"],
  "license": "MIT"
}
